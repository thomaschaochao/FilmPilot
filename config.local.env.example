# FilmPilot local provider configuration.
# Copy this file to config.local.env, fill in the keys you use, then restart FilmPilot.
# config.local.env is ignored by Git. Never commit real API keys.

FILMAGENT_DEEPSEEK_API_KEY=
FILMAGENT_OPENAI_API_KEY=
FILMAGENT_ARK_API_KEY=

FILMAGENT_DEEPSEEK_BASE_URL=https://api.deepseek.com
FILMAGENT_DEEPSEEK_MODEL=deepseek-v4-flash
FILMAGENT_DEEPSEEK_TIMEOUT_SECONDS=120
FILMAGENT_DEEPSEEK_MAX_TOKENS=32768
FILMAGENT_DEEPSEEK_THINKING_ENABLED=true
FILMAGENT_DEEPSEEK_REASONING_EFFORT=high

FILMAGENT_OPENAI_BASE_URL=https://api.openai.com/v1
FILMAGENT_OPENAI_IMAGE_MODEL=gpt-image-2

FILMAGENT_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
FILMAGENT_SEEDREAM_MODEL=doubao-seedream-5-0-260128

FILMAGENT_IMAGE_TIMEOUT_SECONDS=300

# Optional local RAG. Install with: pip install -e ".[rag]"
# First release is fixed to Qdrant Local; Pinecone, Weaviate, and Milvus are intentionally not configured.
FILMAGENT_EMBEDDING_ENABLED=true
FILMAGENT_EMBEDDING_MODEL=BAAI/bge-m3
FILMAGENT_EMBEDDING_DEVICE=auto
FILMAGENT_EMBEDDING_MAX_LENGTH=2048
FILMAGENT_EMBEDDING_CPU_BATCH_SIZE=4
FILMAGENT_EMBEDDING_GPU_BATCH_SIZE=16
FILMAGENT_EMBEDDING_MODEL_PATH=storage/models/bge-m3
FILMAGENT_QDRANT_PATH=storage/vector/qdrant
FILMAGENT_VECTOR_COLLECTION=filmagent_knowledge_v1

# Optional web research fallback. Set this to an Ark model/endpoint with Web Search enabled.
FILMAGENT_ARK_SEARCH_MODEL=
FILMAGENT_WEB_TIMEOUT_SECONDS=30
FILMAGENT_WEB_MAX_BYTES=2000000
FILMAGENT_MASTER_AGENT_AI_ENABLED=true

# Master agent orchestration. CrewAI is optional; install with: pip install -e ".[agents]"
FILMAGENT_AGENT_FRAMEWORK=crewai
FILMAGENT_CREWAI_ENABLED=true
